// Top-level address map for chip_top.
//
// Used exclusively for UVM RAL model generation via peakrdl-uvm. The two
// sub-maps are compiled independently for RTL generation (see registers.py);
// this file exists only so the UVM environment has a single unified register
// model that covers both the AXI-attached DAC and the SPI-attached ADC.
//
// Address layout (16-bit, byte-addressed, 16-bit registers):
//
//   0x0000 - 0x7FFF   adc_regs::ADC_CONV_MEM  (via adc_regs, 32 Ki x 16-bit)
//   0x8000 - 0x80FF   adc_regs   (SPI passthrough, external device)
//   0x80FF - 0x81FF   dac_regs   (AXI4-Lite, on-fabric)
//
// The DAC and ADC sub-maps are each given 256-byte (0x100) windows, which is
// the next power-of-2 that comfortably fits the current register count and
// leaves headroom for expansion. PeakRDL requires power-of-2 alignment for
// sub-map boundaries.

`include "adc_registers.rdl"
`include "dac_registers.rdl"

addrmap chip_top {
    desc = "Top-level chip address map (DAC via AXI4-Lite, ADC+MEM via SPI)";
    default accesswidth = 8;

    // ADC register block + conversion memory — off-fabric, accessed via SPI.
    // RTL compiled separately with peakrdl-regblock + passthrough CPUIF.
    // ADC_CONV_MEM is declared external in adc_registers.rdl; the SPI master
    // provides the physical access path.
    adc_regs ADC @ 0x0000;

    // DAC register block — on-fabric, accessed via AXI4-Lite.
    // RTL compiled separately with peakrdl-regblock + AXI4-Lite CPUIF.
    dac_regs DAC @ 0x80FF;
};
